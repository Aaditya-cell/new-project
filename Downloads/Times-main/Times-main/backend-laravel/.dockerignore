# Git
.git
.gitignore

# Environment variables (keep .env.example for Docker builds)
.env
.env.backup

# Composer dependencies (Docker will install its own)
/vendor

# Node dependencies and built assets (if applicable)
/node_modules
npm-debug.log
yarn-error.log

# Laravel specific
/storage/*.key
/storage/logs/*.log
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*

# OS generated files
.DS_Store
Thumbs.db